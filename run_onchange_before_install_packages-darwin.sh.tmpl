{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash

brew bundle --no-lock --file=/dev/stdin <<EOF
tap "homebrew/cask"
cask_args appdir: "/Applications"

# General
brew "mtr"
brew "nmap"
cask "rectangle"
brew "wget"

# Development
brew "asdf"
cask "copilot-cli"
cask "docker"
brew "gh"
cask "ghostty"
brew "git"
cask "github-copilot-app"
tap "heroku/brew"
brew "heroku"
cask "ngrok"
cask "visual-studio-code"

# Specific Apps

## RecRec Manager
brew "postgresql@16"

## ILSA / DOD website
brew "hugo"
EOF
{{ end -}}
